{
  "name": "Patreon-desktop",
  "version": "1.0.0",
  "author": "Patreon+",
  "description": "Desktop client for https://sites.google.com/view/patreonpluss/home",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --win --publish never"
  },
  "build": {
    "appId": "com.yourdomain.app",
    "productName": "Patreon",
    "files": [
      "src/**/*"
    ],
    "win": {
      "target": "nsis",
      "icon": "src/female_woman_girl_person_user_client_1470.ico"
    },
    "nsis": {
      "installerIcon": "src/female_woman_girl_person_user_client_1470.ico",
      "uninstallerIcon": "src/female_woman_girl_person_user_client_1470.ico"
    }
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0"
  }
}
